# Example ~/.xsessionrc runtime tuning for the pointer inertia extension.
# Replace TOUCHPAD NAME with the exact name reported by:
#   xinput list --name-only

TOUCHPAD="TOUCHPAD NAME"

xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia" 1
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Motion" \
  3.1 0.88 1658 1.9 0.75 0.45
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Timing" \
  50 150 24 200 0
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Sampling" \
  8 10
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Behavior" \
  1 1
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia ClickGen TapTime" \
  128
xinput set-prop "$TOUCHPAD" "Synaptics Locked Drags" 0
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Drag Lock" \
  1 0 1
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Drag Lock Cancel" \
  0
xinput set-prop "$TOUCHPAD" "Synaptics Pointer Inertia Debug" 0

if command -v pointer-inertia-esc-cancel >/dev/null 2>&1; then
  pkill -u "$USER" -f '(^|/)pointer-inertia-esc-cancel( |$)' 2>/dev/null || true
  pointer-inertia-esc-cancel -v >/tmp/pointer-inertia-esc-cancel.log 2>&1 &
fi

# Useful companion Synaptics settings for this tuning. They are not required
# by the driver extension, but were used during practical testing.
xinput set-prop "$TOUCHPAD" "Synaptics Tap Time" 96
xinput set-prop "$TOUCHPAD" "Synaptics Tap Move" 12
xinput set-prop "$TOUCHPAD" "Synaptics Tap Action" 0 9 0 8 1 3 2
